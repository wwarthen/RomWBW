CLI_PREP:
	LD	HL,CLIARGS		; COMMAND TAIL START
	LD	DE,CLIBUF
	LD	B,128			; MAX CP/M COMMAND TAIL LENGTH
CLI_PREP1:
	LD	A,B
	OR	A
	JR	Z,CLI_PREP3
	LD	A,(HL)
	CP	13			; CR TERMINATOR
	JR	Z,CLI_PREP3
	OR	A			; ALLOW NUL-TERMINATED TAILS TOO
	JR	Z,CLI_PREP3
	LD	(DE),A
	INC	HL
	INC	DE
	DEC	B
	JR	CLI_PREP1
CLI_PREP3:
	XOR	A
	LD	(DE),A			; NUL TERMINATE
	RET

CLI_SHOW_HELP:
 	LD	HL, CLIBUF		; TEST FOR -HELP ON COMMAND LINE
	LD	DE, HELPOPT1
	CALL	STRINDEX
	JR	Z, CLI_SHOW_HELP1
 	LD	HL, CLIBUF		; TEST FOR --HELP ON COMMAND LINE
	LD	DE, HELPOPT2
	CALL	STRINDEX
	JR	Z, CLI_SHOW_HELP1
 	LD	HL, CLIBUF		; TEST FOR -help ON COMMAND LINE
	LD	DE, HELPOPT3
	CALL	STRINDEX
	JR	Z, CLI_SHOW_HELP1
 	LD	HL, CLIBUF		; TEST FOR --help ON COMMAND LINE
	LD	DE, HELPOPT4
	CALL	STRINDEX
	RET	NZ
CLI_SHOW_HELP1:
	JP	HELPMSG

CLI_HAVE_ALL_SWITCH:
	LD	HL, CLIBUF		; TEST FOR -LIST ON COMMAND LINE
	LD	DE, LISTOPT1
	CALL	STRINDEX
	JR	Z, CLI_HAVE_ALL_SWITCH1
	LD	HL, CLIBUF		; TEST FOR --LIST ON COMMAND LINE
	LD	DE, LISTOPT2
	CALL	STRINDEX
	JR	Z, CLI_HAVE_ALL_SWITCH1
	LD	HL, CLIBUF		; TEST FOR -list ON COMMAND LINE
	LD	DE, LISTOPT3
	CALL	STRINDEX
	JR	Z, CLI_HAVE_ALL_SWITCH1
	LD	HL, CLIBUF		; TEST FOR --list ON COMMAND LINE
	LD	DE, LISTOPT4
	CALL	STRINDEX
	JR	Z, CLI_HAVE_ALL_SWITCH1
	LD	HL, CLIBUF		; LEGACY: TEST FOR -ALL ON COMMAND LINE
	LD	DE, ALLOPT1
	CALL	STRINDEX
	JR	Z, CLI_HAVE_ALL_SWITCH1
	LD	HL, CLIBUF		; LEGACY: TEST FOR --ALL ON COMMAND LINE
	LD	DE, ALLOPT2
	CALL	STRINDEX
	JR	Z, CLI_HAVE_ALL_SWITCH1
	LD	HL, CLIBUF		; LEGACY: TEST FOR -all ON COMMAND LINE
	LD	DE, ALLOPT3
	CALL	STRINDEX
	JR	Z, CLI_HAVE_ALL_SWITCH1
	LD	HL, CLIBUF		; LEGACY: TEST FOR --all ON COMMAND LINE
	LD	DE, ALLOPT4
	CALL	STRINDEX
	JR	NZ, CLI_HAVE_ALL_SWITCH2
CLI_HAVE_ALL_SWITCH1:
	OR	$FF			; MATCHED -LIST / -list (or legacy -ALL)
	LD	(ALLMD), A
	RET
CLI_HAVE_ALL_SWITCH2:
	XOR	A
	LD	(ALLMD), A
	RET

CLI_HAVE_LOOP_SWITCH:
 	LD	HL, CLIBUF		; TEST FOR -LOOP ON COMMAND LINE
	LD	DE, LOOPOPT1
	CALL	STRINDEX
	JR	Z, CLI_HAVE_LOOP_SWITCH1
 	LD	HL, CLIBUF		; TEST FOR --LOOP ON COMMAND LINE
	LD	DE, LOOPOPT2
	CALL	STRINDEX
	JR	Z, CLI_HAVE_LOOP_SWITCH1
 	LD	HL, CLIBUF		; TEST FOR -loop ON COMMAND LINE
	LD	DE, LOOPOPT3
	CALL	STRINDEX
	JR	Z, CLI_HAVE_LOOP_SWITCH1
 	LD	HL, CLIBUF		; TEST FOR --loop ON COMMAND LINE
	LD	DE, LOOPOPT4
	CALL	STRINDEX
	JR	NZ, CLI_HAVE_LOOP_SWITCH2
CLI_HAVE_LOOP_SWITCH1:
	LD	A,(ALLMD)
	OR	A
	JR	Z,CLI_HAVE_LOOP_SWITCH1A
	OR	$FF			; MATCHED -LOOP / -loop in playlist mode
	LD	(LOOPPLMD),A
	XOR	A
	LD	(LOOPTRKMD),A
	RET
CLI_HAVE_LOOP_SWITCH1A:
	OR	$FF			; MATCHED -LOOP / -loop in single-track mode
	LD	(LOOPTRKMD),A
	XOR	A
	LD	(LOOPPLMD),A
	RET
CLI_HAVE_LOOP_SWITCH2:
	XOR	A
	LD	(LOOPTRKMD), A
	LD	(LOOPPLMD), A
	RET

CLI_HAVE_CONFIG_SWITCH:
 	LD	HL, CLIBUF		; TEST FOR -CONFIG ON COMMAND LINE
	LD	DE, CFGOPT1
	CALL	STRINDEX
	JR	Z, CLI_HAVE_CONFIG_SWITCH1
 	LD	HL, CLIBUF		; TEST FOR --CONFIG ON COMMAND LINE
	LD	DE, CFGOPT2
	CALL	STRINDEX
	JR	Z, CLI_HAVE_CONFIG_SWITCH1
 	LD	HL, CLIBUF		; TEST FOR -config ON COMMAND LINE
	LD	DE, CFGOPT3
	CALL	STRINDEX
	JR	Z, CLI_HAVE_CONFIG_SWITCH1
 	LD	HL, CLIBUF		; TEST FOR --config ON COMMAND LINE
	LD	DE, CFGOPT4
	CALL	STRINDEX
	JR	NZ, CLI_HAVE_CONFIG_SWITCH2
CLI_HAVE_CONFIG_SWITCH1:
	OR	$FF			; MATCHED -CONFIG / -config
	LD	(CONFIGMD), A
	RET
CLI_HAVE_CONFIG_SWITCH2:
	XOR	A
	LD	(CONFIGMD), A
	RET

CLI_ABRT_IF_OPT_FIRST:
	LD	A, (FCB+1)
	CP	'-'			; OPTION FIRST OR - MISSING FILENAME?
	RET	NZ
	LD	A,(ALLMD)
	OR	A
	RET	NZ			; ALLOW OPTION-FIRST WHEN -LIST IS USED
	LD	A,(CONFIGMD)
	OR	A
	RET	NZ			; ALLOW OPTION-FIRST WHEN -config IS USED
	JP	ERRCMD			; SHOW USAGE
	RET

CLI_HAVE_HBIOS_SWITCH:
 	LD	HL, CLIBUF		; TEST FOR --HBIOS ON COMMAND LINE
	LD	DE, HBIOSOPT
	CALL	STRINDEX
	JR	NZ, CLI_HAVE_HBIOS_SWITCH1
	OR	$FF			; MATCHED --HBIOS
	LD	(HBIOSMD), A
	LD	BC,(BF_SYSGET*256)+BF_SND
	RST	08			; CHECK WE HAVE
	XOR	A			; AT LEAST ONE
	CP	E			; SOUND DEVICE
	RET	NZ
	JP	ERRHW
CLI_HAVE_HBIOS_SWITCH1			; NOT MATCHED --HBIOS
	XOR	A
	LD	(HBIOSMD), A
	RET

CLI_HAVE_DELAY_SWITCH:
 	LD	HL, CLIBUF		; TEST FOR --DELAY ON COMMAND LINE
	LD	DE, DELAYOPT
	CALL	STRINDEX
	JR	NZ, CLI_HAVE_DELAY_SWITCH1
	OR	$FF			; MATCHED --DELAY
	LD	(DELAYMD), A
	RET
CLI_HAVE_DELAY_SWITCH1			; NOT MATCHED --DELAY
	XOR	A
	LD	(DELAYMD), A
	RET

CLI_PORTS:
 	LD	HL, CLIBUF		; TEST FOR -MSX ON COMMAND LINE
	LD	DE, OPT_MSX
	CALL	STRINDEX
	JR	NZ, CLI_PORTS1
	LD	A,PORTS_MSX
	JR	CLI_PORTS_Z
CLI_PORTS1:
 	LD	HL, CLIBUF		; TEST FOR -RC ON COMMAND LINE
	LD	DE, OPT_RC
	CALL	STRINDEX
	JR	NZ, CLI_PORTS2
	LD	A,PORTS_RC
	JR	CLI_PORTS_Z
CLI_PORTS2:
 	LD	HL, CLIBUF		; TEST FOR -COLECO ON COMMAND LINE
	LD	DE, OPT_COLECO
	CALL	STRINDEX
	JR	NZ, CLI_PORTS3
	LD	A,PORTS_COLECO
	JR	CLI_PORTS_Z
CLI_PORTS3:
	LD	A,PORTS_AUTO		; USE AUTO PORT SELECTION
CLI_PORTS_Z:
	LD	(USEPORTS),A		; SAVE PORTS SELECTION
	RET

CLI_ABRT_UNSUPPFILTYP:
	PUSH	AF
	ISHBIOS
	JR	Z, CLI_ABRT_UNSUPPFILTYP1
	POP	AF
	CP	TYPMYM
	RET	NZ
	ERRWITHMSG(MSGUNSUP)		; EXIT WITH UNSUPPORTED FILE TYPE MESSAGE

CLI_ABRT_UNSUPPFILTYP1:
	POP	AF
	RET

CLI_OCTAVE_ADJST:			; SEARCH FOR OCTAVE ADJUSTMENT SWITCH (-n or +n)
	LD	HL, CLIBUF		; TEST FOR --HBIOS ON COMMAND LINE
	LD	DE, DOWN1
	CALL	STRINDEX
	JR	NZ, CLI_OCTAVE_ADJST1

	LD	A, -1
	JR 	CLI_OCTAVE_ADJST5

CLI_OCTAVE_ADJST1:
	LD	HL, CLIBUF		; TEST FOR --HBIOS ON COMMAND LINE
	LD	DE, DOWN2
	CALL	STRINDEX
	JR	NZ, CLI_OCTAVE_ADJST2

	LD	A, -2
	JR 	CLI_OCTAVE_ADJST5

CLI_OCTAVE_ADJST2:
	LD	HL, CLIBUF		; TEST FOR --HBIOS ON COMMAND LINE
	LD	DE, UP1
	CALL	STRINDEX
	JR	NZ, CLI_OCTAVE_ADJST3

	LD	A, 1
	JR 	CLI_OCTAVE_ADJST5

CLI_OCTAVE_ADJST3:
	LD	HL, CLIBUF		; TEST FOR --HBIOS ON COMMAND LINE
	LD	DE, UP2
	CALL	STRINDEX
	JR	NZ, CLI_OCTAVE_ADJST4

	LD	A, 2
	JR 	CLI_OCTAVE_ADJST5

CLI_OCTAVE_ADJST4:
	LD	A, 0

CLI_OCTAVE_ADJST5:
	LD	(OCTAVEADJ), A
	RET

OPT_MSX		.DB	"-MSX", 0			; USE MSX PORTS
OPT_RC		.DB	"-RC", 0			; USE RC PORTS
OPT_COLECO	.DB	"-COLECO", 0			; USE COLECO AY PORTS (50H/51H)
LISTOPT1	.DB	"-LIST", 0			; ENUMERATE/PLAY ALL SUPPORTED FILES
LISTOPT2	.DB	"--LIST", 0			; ENUMERATE/PLAY ALL SUPPORTED FILES
LISTOPT3	.DB	"-list", 0			; ENUMERATE/PLAY ALL SUPPORTED FILES
LISTOPT4	.DB	"--list", 0			; ENUMERATE/PLAY ALL SUPPORTED FILES
ALLOPT1		.DB	"-ALL", 0			; LEGACY ALIAS FOR -LIST
ALLOPT2		.DB	"--ALL", 0			; LEGACY ALIAS FOR -LIST
ALLOPT3		.DB	"-all", 0			; LEGACY ALIAS FOR -LIST
ALLOPT4		.DB	"--all", 0			; LEGACY ALIAS FOR -LIST
LOOPOPT1	.DB	"-LOOP", 0			; LOOP PLAYBACK
LOOPOPT2	.DB	"--LOOP", 0			; LOOP PLAYBACK
LOOPOPT3	.DB	"-loop", 0			; LOOP PLAYBACK
LOOPOPT4	.DB	"--loop", 0			; LOOP PLAYBACK
CFGOPT1		.DB	"-CONFIG", 0			; TUNE.CFG CONFIG MODE
CFGOPT2		.DB	"--CONFIG", 0			; TUNE.CFG CONFIG MODE
CFGOPT3		.DB	"-config", 0			; TUNE.CFG CONFIG MODE
CFGOPT4		.DB	"--config", 0			; TUNE.CFG CONFIG MODE
HELPOPT1	.DB	"-HELP", 0			; SHOW HELP/USAGE
HELPOPT2	.DB	"--HELP", 0			; SHOW HELP/USAGE
HELPOPT3	.DB	"-help", 0			; SHOW HELP/USAGE
HELPOPT4	.DB	"--help", 0			; SHOW HELP/USAGE
HBIOSOPT:	.DB	"--HBIOS", 0			; USE HBIOS API FOR PLAYBACK
DELAYOPT:	.DB	"-DELAY",0			; FORCE DELAY MODE
DOWN1		.DB	"-t1", 0			; DOWN AN OCTAVE
DOWN2		.DB	"-t2", 0			; DOWN TWO OCTAVE
UP1		.DB	"+t1", 0			; UP AN OCTAVE
UP2		.DB	"+t2", 0			; UP TWO OCTAVE
